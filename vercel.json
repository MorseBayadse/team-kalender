{
  "rewrites": [
    {
      "source": "/css/styles.css",
      "destination": "/styles.css"
    },
    {
      "source": "/js/app.js",
      "destination": "/app.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
